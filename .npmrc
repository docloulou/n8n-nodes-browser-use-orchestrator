# Réseau résilient pour les installs CI (registre npm parfois instable :
# ECONNRESET / network aborted). On retente plusieurs fois avec un backoff
# et des timeouts généreux. Ces réglages sont lus par npm en local comme en CI.
fetch-retries=5
fetch-retry-factor=4
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=600000
